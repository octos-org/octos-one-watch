+    //
+    // Apps can select a composer theme and layout through manifest metadata.
+    // Both hooks are optional, so existing cargo-makepad apps keep the stock
+    // teal, phone-width composer without changing their manifests.
+    private String composerMetaData(String key) {
+        try {
+            ApplicationInfo ai = getPackageManager().getApplicationInfo(
+                getPackageName(), PackageManager.GET_META_DATA);
+            if (ai.metaData != null) {
+                return ai.metaData.getString(key, "");
+            }
+        } catch (Exception ignored) {}
+        return "";
+    }
+
+    private boolean composerThemeIsMono() {
+        return "mono".equals(composerMetaData("makepad.COMPOSER_THEME"));
+    }
+
+    private boolean composerLayoutIsWatch() {
+        return "watch".equals(composerMetaData("makepad.COMPOSER_LAYOUT"));
+    }
